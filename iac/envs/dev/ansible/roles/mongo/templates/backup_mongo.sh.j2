#!/bin/bash
set -e

# Configuration
BUCKET_NAME="{{ s3_bucket_name }}"
REGION="{{ aws_region | default('us-east-1') }}"
TIMESTAMP=$(date +%Y-%m-%d_%H-%M-%S)
BACKUP_FILE="mongo-backup-$TIMESTAMP.gz"

# Fetch credentials from SSM Parameter Store at runtime
MONGO_USER=$(aws ssm get-parameter \
  --name "/wiz-exercise/dev/mongo-admin-user" \
  --with-decryption --query 'Parameter.Value' --output text \
  --region "$REGION")

MONGO_PASS=$(aws ssm get-parameter \
  --name "/wiz-exercise/dev/mongo-admin-password" \
  --with-decryption --query 'Parameter.Value' --output text \
  --region "$REGION")

# Dump and compress
mongodump --host localhost --port 27017 \
  --username "$MONGO_USER" --password "$MONGO_PASS" \
  --authenticationDatabase admin --archive | gzip > "/tmp/$BACKUP_FILE"

# Upload to S3
aws s3 cp "/tmp/$BACKUP_FILE" "s3://$BUCKET_NAME/$BACKUP_FILE"

# Cleanup
rm -f "/tmp/$BACKUP_FILE"

echo "Backup uploaded to s3://$BUCKET_NAME/$BACKUP_FILE"
