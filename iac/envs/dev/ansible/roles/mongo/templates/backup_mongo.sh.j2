#!/bin/bash
set -e
set -x # Debug mode

# Configuration
BUCKET_NAME="{{ s3_bucket_name }}"
MONGO_USER="{{ mongo_admin_user }}"
MONGO_PASS="{{ mongodb_password }}"
TIMESTAMP=$(date +%Y-%m-%d_%H-%M-%S)
BACKUP_FILE="mongo-backup-$TIMESTAMP.gz"

# Dump and compress
mongodump --host localhost --port 27017 --username "$MONGO_USER" --password "$MONGO_PASS" --authenticationDatabase admin --archive | gzip > "/tmp/$BACKUP_FILE"

# Upload to S3
aws s3 cp "/tmp/$BACKUP_FILE" "s3://$BUCKET_NAME/$BACKUP_FILE"

# Cleanup
rm -f "/tmp/$BACKUP_FILE"

echo "Backup uploaded to s3://$BUCKET_NAME/$BACKUP_FILE"



